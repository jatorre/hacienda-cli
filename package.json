{
  "name": "hacienda-cli",
  "version": "0.3.0",
  "description": "CLI para interactuar con la sede electrónica de la AEAT. Descarga/sube declaraciones en formato XML oficial. Nunca presenta ni firma.",
  "type": "module",
  "bin": {
    "hacienda": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "playwright": "^1.48.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "typescript": "^5.6.0"
  },
  "license": "AGPL-3.0-or-later"
}
